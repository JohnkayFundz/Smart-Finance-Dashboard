<form id="budgetForm" novalidate>

    <div class="form-group">
        <label for="budgetName">
            Budget Name
        </label>

        <input
            id="budgetName"
            name="budgetName"
            type="text"
            placeholder="e.g. Food"
            required
            maxlength="50"
            autocomplete="off">
    </div>

    <div class="form-group">
        <label for="budgetAmount">
            Budget Amount
        </label>

        <input
            id="budgetAmount"
            name="budgetAmount"
            type="number"
            min="0"
            step="0.01"
            placeholder="0.00"
            required>
    </div>

    <div class="form-group">
        <label for="budgetCategory">
            Category
        </label>

        <select
            id="budgetCategory"
            name="budgetCategory"
            required>

            <option value="">
                Select a category
            </option>

        </select>
    </div>

    <div class="modal-footer">

        <button
            type="submit"
            class="btn-primary">
            Save Budget
        </button>

        <button
            type="button"
            class="btn-secondary"
            data-close-modal>
            Cancel
        </button>

    </div>

</form>
