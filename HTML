<!-- Budget Modal -->
<div id="budgetModal" class="modal">
  <div class="modal-content">
    <span id="closeBudgetModal" class="close">&times;</span>
    <h2>Add Budget</h2>
    <form id="budgetForm">
      <label for="budgetName">Budget Name</label>
      <input type="text" id="budgetName" placeholder="e.g. Food Budget" required>

      <label for="budgetAmount">Amount</label>
      <input type="number" id="budgetAmount" step="0.01" required>

      <label for="budgetCategory">Category</label>
      <input type="text" id="budgetCategory" placeholder="e.g. Food" required>

      <button type="submit">Save Budget</button>
    </form>
  </div>
</div>
