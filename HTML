<!-- Trigger button -->
<button type="button" id="openBudgetModal">
  Open Budget Modal
</button>

<!-- Modal -->
<div
    id="budgetModal"
    class="modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="budgetModalTitle"
    aria-describedby="budgetModalDescription"
    aria-hidden="true">

    <div class="modal-content" tabindex="-1">

        <header class="modal-header">
            <h2 id="budgetModalTitle">Budget</h2>
            <p id="budgetModalDescription">Create or edit a budget.</p>

            <button
                type="button"
                id="closeBudgetModal"
                class="close-btn"
                aria-label="Close dialog">
                ×
            </button>
        </header>

        <div class="modal-body">
            <!-- Form goes here -->
        </div>

    </div>
</div>
