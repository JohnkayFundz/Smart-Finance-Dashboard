<div
    id="budgetModal"
    class="modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="budgetModalTitle"
    aria-describedby="budgetModalDescription"
    aria-hidden="true">

    <div
        class="modal-content"
        tabindex="-1">

        <header class="modal-header">
            <h2 id="budgetModalTitle">
                Budget
            </h2>

            <button
                type="button"
                id="closeBudgetModal"
                class="close-btn"
                aria-label="Close dialog">
                ×
            </button>
        </header>

        <div class="modal-body">

            <p id="budgetModalDescription" class="sr-only">
                Create or edit a budget.
            </p>

            <!-- Form goes here -->

        </div>

    </div>

</div>
